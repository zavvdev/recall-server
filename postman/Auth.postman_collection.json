{
  "info": {
    "_postman_id": "1ceca3ac-d598-4c05-b172-80bf33a502a2",
    "name": "Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "37575400"
  },
  "item": [
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.environment.set(\"ACCESS_TOKEN\", json.data.access);",
              "pm.environment.set(\"REFRESH_TOKEN\", json.data.refresh);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"test\",\n    \"password\": \"12345678\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{API_ENDPOINT}}/auth/login/",
          "host": [
            "{{API_ENDPOINT}}"
          ],
          "path": [
            "auth",
            "login",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "Refresh",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.environment.set(\"ACCESS_TOKEN\", json.data.access);",
              "pm.environment.set(\"REFRESH_TOKEN\", json.data.refresh);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"refresh\": \"{{REFRESH_TOKEN}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{API_ENDPOINT}}/auth/refresh/",
          "host": [
            "{{API_ENDPOINT}}"
          ],
          "path": [
            "auth",
            "refresh",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"test\",\n    \"email\": \"test@test.com\",\n    \"password\": \"12345678\",\n    \"name\": \"John Doe\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{API_ENDPOINT}}/auth/register/",
          "host": [
            "{{API_ENDPOINT}}"
          ],
          "path": [
            "auth",
            "register",
            ""
          ]
        }
      },
      "response": []
    }
  ]
}